{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Validate YAML",
      "type": "shell",
      "command": "${workspaceFolder}\\.venv\\Scripts\\python.exe",
      "args": [
        "${workspaceFolder}\\scripts\\validate_site.py"
      ],
      "group": "build",
      "problemMatcher": []
    },
    {
      "label": "Update Site (Prompt)",
      "type": "shell",
      "command": "${workspaceFolder}\\.venv\\Scripts\\python.exe",
      "args": [
        "${workspaceFolder}\\scripts\\update_site.py",
        "${input:updatePrompt}"
      ],
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      },
      "problemMatcher": []
    }
  ],
  "inputs": [
    {
      "id": "updatePrompt",
      "type": "promptString",
      "description": "홈페이지 수정 지시를 입력하세요",
      "default": "Research Themes를 전문적인 문장으로 정리하고 subtopics를 보완해줘."
    }
  ]
}